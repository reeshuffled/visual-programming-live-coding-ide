{
  "name": "visual-live-coding-ide",
  "version": "1.0.0",
  "type": "module",
  "description": "Visual live coding IDE — shaders, audio, media, vision",
  "license": "AGPL-3.0-or-later",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "build": "node node_modules/vite/bin/vite.js build",
    "test": "node node_modules/vitest/vitest.mjs run",
    "lint": "node node_modules/oxlint/dist/cli.js",
    "lint:fix": "node node_modules/oxlint/dist/cli.js --fix",
    "format": "node node_modules/oxfmt/dist/cli.js --write src",
    "format:check": "node node_modules/oxfmt/dist/cli.js --check src",
    "electron:dev": "concurrently -k -n vite,electron \"npm run dev\" \"wait-on tcp:5173 && cross-env ELECTRON_START_URL=http://localhost:5173/createos/ electron electron/main.cjs\"",
    "electron:build": "cross-env ELECTRON=1 npm run build && electron-builder",
    "test:e2e": "cross-env ELECTRON=1 npm run build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.createos.app",
    "productName": "CreateOS",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.2",
    "@grame/faustwasm": "^0.16.5",
    "@huggingface/transformers": "^4.2.0",
    "@mediapipe/tasks-text": "^0.10.35",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@strudel/core": "^1.2.6",
    "@strudel/mini": "^1.2.6",
    "@strudel/tonal": "^1.2.6",
    "@strudel/webaudio": "^1.3.0",
    "blockly": "^13.0.0",
    "esprima": "^4.0.1",
    "obscenity": "^0.4.6",
    "pixi.js": "^7.4.3",
    "sentiment": "^5.0.2",
    "three": "^0.184.0",
    "tone": "^15.1.22"
  },
  "allowScripts": {
    "electron@33.4.11": true
  }
}
